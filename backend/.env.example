# Backend local environment (Spring reads this as .properties)
# Copy to .env and fill values (DO NOT COMMIT .env)

# --- M-Pesa ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
# Cloudflare tunnel URL must end with /api/mpesa/callback
MPESA_CALLBACK_URL=https://<your-cloudflare-tunnel>.trycloudflare.com/api/mpesa/callback

# --- Cloudflare R2 (S3-compatible) ---
CLOUDFLARE_R2_ENABLED=false
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
# Public URL prefix that serves objects (custom domain recommended)
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://images.yourdomain.com
# Optional; defaults to https://<account-id>.r2.cloudflarestorage.com
#CLOUDFLARE_R2_ENDPOINT=
# Optional key prefix within the bucket
CLOUDFLARE_R2_KEY_PREFIX=products
